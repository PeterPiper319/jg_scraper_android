{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Industry Schema",
  "description": "Schema and data for each industry in the JG TenderMatch application, including its unique identifier, display name, specializations, skills, and capabilities.",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "The unique snake_case identifier for the industry."
    },
    "name": {
      "type": "string",
      "description": "The human-readable display name of the industry."
    },
    "specializations": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Specific focus areas or sub-sectors within the industry."
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Professional skills and domain expertise typical of businesses in this industry."
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Physical assets, equipment, tools, regulatory registrations, or certifications required to operate."
    }
  },
  "required": [
    "id",
    "name",
    "specializations",
    "skills",
    "capabilities"
  ],
